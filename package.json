{
  "name": "creator-credentials-ui",
  "version": "0.0.0",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "next build --webpack",
    "changeset:build": "pnpm tsc ./.changeset/changelog.generator.ts",
    "check:licenses": "node check-licenses.js",
    "dev": "docker compose --env-file .env.local -f docker/docker-compose.local.yaml up -d --build",
    "docker:base:dev": "docker compose --env-file .env.local -f docker/docker-compose.local.yaml up -d --build",
    "docker:base:prod": "docker compose --env-file .env.local.prod -f docker/docker-compose.prod.yaml up -d --build",
    "lint": "eslint --max-warnings=0 .",
    "prepare": "husky install",
    "prettier:check": "prettier -c .",
    "prettier:fix": "prettier . --write",
    "pre-commit": "lint-staged",
    "pre-push": "pnpm prettier:check && pnpm lint && pnpm test:unit --run && pnpm changeset status",
    "start:dev": "next dev --webpack",
    "start:docker": "pnpm docker:base:dev up -V",
    "start:docker:prod": "pnpm docker:base:prod up",
    "start:prod": "next start -p $FRONTEND_APP_PORT",
    "start:prod:local": "next start",
    "test:unit": "tsc --p tsconfig.test.json && vitest"
  },
  "dependencies": {
    "@clerk/nextjs": "7.2.7",
    "@hookform/resolvers": "5.2.2",
    "@metamask/sdk": "0.34.0",
